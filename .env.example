# Copy to `.env` in this folder for local development.
# Production: set these in Vercel → Project → Settings → Environment Variables (you’ve added CMS_PUBLIC_URL there).

# CMS public origin (HTTPS in production, e.g. https://your-cms.vercel.app)
CMS_PUBLIC_URL=

# Canonical portfolio URL for metadata (HTTPS)
NEXT_PUBLIC_SITE_URL=

# Optional: POST /api/revalidate from the CMS or CI to refresh cached CMS data
# REVALIDATE_SECRET=
